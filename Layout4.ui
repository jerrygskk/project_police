      <!-- 狀態標籤 -->
      <item>
       <widget class="QLabel" name="lbl_status">
        <property name="text"><string></string></property>
        <property name="styleSheet"><string>color: gray; font-size: 12px;</string></property>
       </widget>
      </item>

      <!-- 彈性空間（把右側兩顆按鈕推到最右） -->
      <item>
       <spacer name="hSpacer">
        <property name="orientation"><enum>Qt::Horizontal</enum></property>
        <property name="sizeHint" stdset="0">
         <size><width>40</width><height>20</height></size>
        </property>
       </spacer>
      </item>

      <!-- 下載 PDF 按鈕 -->
      <item>
       <widget class="QPushButton" name="btn_download">
        <property name="text"><string>下載 PDF</string></property>
        <property name="enabled"><bool>false</bool></property>
       </widget>
      </item>

      <!-- 列印表單按鈕 -->
      <item>
       <widget class="QPushButton" name="btn_print">
        <property name="text"><string>列印表單</string></property>
        <property name="enabled"><bool>false</bool></property>
       </widget>
      </item>

     </layout>
    </item>

    <!-- 預覽捲動區 -->
    <item>
     <widget class="QScrollArea" name="scroll_preview">
      <property name="widgetResizable"><bool>true</bool></property>
      <property name="styleSheet"><string>background: #D0D0D0;</string></property>
