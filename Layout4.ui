    <property name="topMargin"><number>16</number></property>
    <property name="rightMargin"><number>16</number></property>
    <property name="bottomMargin"><number>16</number></property>

    <!-- 控制列 -->
    <item>
     <layout class="QHBoxLayout" name="ctrlLayout">
      <property name="spacing"><number>10</number></property>

      <!-- 發文日期 標籤 -->
      <item>
       <widget class="QLabel" name="lbl_date">
        <property name="text"><string>發文日期：</string></property>
        <property name="alignment"><set>Qt::AlignRight|Qt::AlignVCenter</set></property>
       </widget>
      </item>

      <!-- 日期選擇器 -->
      <item>
       <widget class="QDateEdit" name="print_date">
        <property name="minimumWidth"><number>120</number></property>
        <property name="calendarPopup"><bool>true</bool></property>
        <property name="displayFormat"><string>yyyy-MM-dd</string></property>
       </widget>
      </item>

      <!-- 產生預覽按鈕 -->
      <item>
       <widget class="QPushButton" name="btn_generate">
        <property name="text"><string>產生預覽</string></property>
       </widget>
