<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>MainWindow</class>
 <widget class="QMainWindow" name="MainWindow">
  <property name="geometry">
   <rect><x>0</x><y>0</y><width>1100</width><height>768</height></rect>
  </property>
  <property name="windowTitle"><string>公文管理系統 - 公文陳報</string></property>
  <widget class="QWidget" name="centralwidget">
   <layout class="QVBoxLayout" name="mainVerticalLayout">
    <property name="spacing"><number>8</number></property>
    <property name="contentsMargins"><number>8</number><number>8</number><number>8</number><number>8</number></property>

    <!-- mainGrid：合併 topGrid + crimGrid + genGrid
         row 0 ：陳報日期／發文人員／清除／確認（共用）
         row 1-3：刑案欄位（發文分類／案件分類／查獲受理）
         row 4-5：一般欄位（發文分類／承辦人）
         欄位：col0=左標 col1=左欄 col2=Fixed16 col3=右標 col4=右欄
               col5=小按鈕 col6=Fixed16 col7=報案人標 col8=報案人欄
               col9=Expanding col10=清除 col11=確認
    -->
    <item>
     <layout class="QGridLayout" name="mainGrid">
      <property name="horizontalSpacing"><number>8</number></property>
      <property name="verticalSpacing"><number>0</number></property>
      <property name="contentsMargins"><number>0</number><number>6</number><number>0</number><number>6</number></property>

      <!-- ── col2 Fixed 16px（rowspan=6） ── -->
      <item row="0" column="2" rowspan="6">
       <spacer><property name="orientation"><enum>Qt::Horizontal</enum></property>
        <property name="sizeHint" stdset="0"><size><width>16</width><height>0</height></size></property>
        <property name="sizeType"><enum>QSizePolicy::Fixed</enum></property></spacer>
      </item>

      <!-- ── col6 Fixed 16px（rowspan=6） ── -->
      <item row="0" column="6" rowspan="6">
       <spacer><property name="orientation"><enum>Qt::Horizontal</enum></property>
        <property name="sizeHint" stdset="0"><size><width>16</width><height>0</height></size></property>
        <property name="sizeType"><enum>QSizePolicy::Fixed</enum></property></spacer>
      </item>

      <!-- ── col9 Expanding（rowspan=6） ── -->
      <item row="0" column="9" rowspan="6">
       <spacer><property name="orientation"><enum>Qt::Horizontal</enum></property>
        <property name="sizeHint" stdset="0"><size><width>0</width><height>0</height></size></property>
        <property name="sizeType"><enum>QSizePolicy::Expanding</enum></property></spacer>
      </item>

      <!-- ════════════════════════════════════════
           row 0：共用（陳報日期／發文人員／按鈕）
           ════════════════════════════════════════ -->
      <item row="0" column="0">
       <widget class="QLabel">
        <property name="text"><string>陳報日期</string></property>
        <property name="alignment"><set>Qt::AlignRight|Qt::AlignVCenter</set></property>
       </widget>
      </item>
      <item row="0" column="1">
       <widget class="QDateEdit" name="rpt_date">
        <property name="minimumSize"><size><width>240</width><height>36</height></size></property>
        <property name="maximumSize"><size><width>240</width><height>36</height></size></property>
        <property name="calendarPopup"><bool>true</bool></property>
        <property name="displayFormat"><string>yyyy-MM-dd</string></property>
       </widget>
      </item>
      <item row="0" column="3">
       <widget class="QLabel">
        <property name="text"><string>發文人員</string></property>
        <property name="alignment"><set>Qt::AlignRight|Qt::AlignVCenter</set></property>
       </widget>
      </item>
      <item row="0" column="4" colspan="2">
       <widget class="QComboBox" name="rpt_sender">
        <property name="editable"><bool>true</bool></property>
       </widget>
      </item>
      <item row="0" column="10">
       <widget class="QPushButton" name="btn_rpt_clear">
        <property name="minimumSize"><size><width>110</width><height>36</height></size></property>
        <property name="maximumSize"><size><width>110</width><height>36</height></size></property>
        <property name="text"><string>清除表單</string></property>
       </widget>
      </item>
      <item row="0" column="11">
       <widget class="QPushButton" name="btn_rpt_submit">
        <property name="minimumSize"><size><width>110</width><height>36</height></size></property>
        <property name="maximumSize"><size><width>110</width><height>36</height></size></property>
        <property name="text"><string>確認陳報</string></property>
       </widget>
      </item>

      <!-- ════════════════════════════════════════
           row 1（刑案）：發文分類 radio ／ 陳報主旨
           ════════════════════════════════════════ -->
      <item row="1" column="0">
       <widget class="QLabel" name="lbl_crim_status">
        <property name="text"><string>發文分類</string></property>
        <property name="alignment"><set>Qt::AlignRight|Qt::AlignVCenter</set></property>
       </widget>
      </item>
      <item row="1" column="1">
       <widget class="QWidget" name="crim_status_group">
        <property name="minimumSize"><size><width>240</width><height>36</height></size></property>
        <layout class="QHBoxLayout" name="statusRadioLayout">
         <property name="spacing"><number>20</number></property>
         <property name="contentsMargins"><number>0</number><number>0</number><number>0</number><number>0</number></property>
         <item><widget class="QRadioButton" name="radio_status_a">
          <property name="text"><string>現行</string></property>
          <property name="checked"><bool>true</bool></property>
          <property name="minimumSize"><size><width>65</width><height>0</height></size></property>
         </widget></item>
         <item><widget class="QRadioButton" name="radio_status_b">
          <property name="text"><string>到案</string></property>
          <property name="minimumSize"><size><width>65</width><height>0</height></size></property>
         </widget></item>
         <item><widget class="QRadioButton" name="radio_status_c">
          <property name="text"><string>未到</string></property>
          <property name="minimumSize"><size><width>65</width><height>0</height></size></property>
         </widget></item>
         <item><spacer><property name="orientation"><enum>Qt::Horizontal</enum></property>
          <property name="sizeHint" stdset="0"><size><width>0</width><height>0</height></size></property></spacer></item>
        </layout>
       </widget>
      </item>
      <item row="1" column="3">
       <widget class="QLabel" name="lbl_crim_subject">
        <property name="text"><string>陳報主旨</string></property>
        <property name="alignment"><set>Qt::AlignRight|Qt::AlignVCenter</set></property>
       </widget>
      </item>
      <item row="1" column="4" colspan="2">
       <widget class="QLineEdit" name="crim_subject">
        <property name="minimumSize"><size><width>0</width><height>36</height></size></property>
        <property name="placeholderText"><string>請輸入嫌疑人或案由</string></property>
       </widget>
      </item>

      <!-- ════════════════════════════════════════
