import sys
import os
import sqlite3
from datetime import datetime
from PySide6.QtWidgets import QApplication, QDialog, QMainWindow, QMessageBox, QTableWidgetItem
from PySide6.QtUiTools import QUiLoader
from PySide6.QtCore import QFile

def getResourcePath(relative_path):
    """取得資源路徑，確保 EXE 封裝後路徑正確"""
    if hasattr(sys, '_MEIPASS'):
        return os.path.join(sys._MEIPASS, relative_path)
    return os.path.join(os.path.abspath("."), relative_path)

class MainWindow(QMainWindow):
    """執行頁面邏輯 (對應 Layout1.ui / image_2d7fdb.png)"""
    def __init__(self, tabIndex=0):
        super().__init__()
        self.uiPath = getResourcePath("Layout1.ui")
        self.dbPath = getResourcePath("dbfile.db")
        self.loadUi(tabIndex)
        self.bindEvents()

    def loadUi(self, tabIndex):
        loader = QUiLoader()
        file = QFile(self.uiPath)
        if file.open(QFile.ReadOnly):
            self.ui = loader.load(file, self)
            file.close()
            self.setCentralWidget(self.ui)
            self.setWindowTitle("公文管理系統")
            if hasattr(self.ui, 'tabWidget'):
                self.ui.tabWidget.setCurrentIndex(tabIndex)

    def bindEvents(self):
        """綁定 UI 事件"""
        if hasattr(self.ui, 'lineEdit_docNum'):
            self.ui.lineEdit_docNum.returnPressed.connect(self.queryTaskData)
        
        if hasattr(self.ui, 'btn_send'):
            self.ui.btn_send.clicked.connect(self.executeDispatch)

    def queryTaskData(self):
        """批次查詢資料並累加至表格"""
        serialNo = self.ui.lineEdit_docNum.text().strip()
        if not serialNo:
            return

        # 檢查表格是否已經存在重複的文號
        if self.isDuplicate(serialNo):
            QMessageBox.information(self, "提醒", f"文號 {serialNo} 已在列表中")
            self.ui.lineEdit_docNum.clear()
            return

        try:
            connection = sqlite3.connect(self.dbPath)
            cursor = connection.cursor()
            
            # 修改重點：直接查詢 View 以取得轉換後的業務組名稱
            # 欄位順序需與表格一致
            sqlQuery = """
                SELECT serial_no, subject, dept_name, assignee_name, dispatch_date, deadline 
                FROM View_Task_Assignment 
                WHERE serial_no = ?
            """
            cursor.execute(sqlQuery, (serialNo,))
            row = cursor.fetchone()
            connection.close()

            if row:
                self.addRecordToTable(row)
                # 修改重點：清空輸入框以便連續輸入
                self.ui.lineEdit_docNum.clear()
            else:
                QMessageBox.warning(self, "查詢結果", f"找不到編號: {serialNo}")
                
        except Exception as e:
            QMessageBox.critical(self, "錯誤", f"資料庫查詢出錯: {str(e)}")

    def isDuplicate(self, serialNo):
        """檢查表格中是否已存在該文號"""
        table = self.ui.tableWidget
        for i in range(table.rowCount()):
            item = table.item(i, 0)
            if item and item.text() == serialNo:
                return True
        return False

    def addRecordToTable(self, rowData):
        """將單筆資料新增到表格末尾 (批次模式)"""
        if not hasattr(self.ui, 'tableWidget'):
            return

        table = self.ui.tableWidget
        currentRowCount = table.rowCount()
        table.insertRow(currentRowCount)

        # 填入 0-5 欄資料
        for i in range(6):
            val = "" if rowData[i] is None else str(rowData[i])
            table.setItem(currentRowCount, i, QTableWidgetItem(val))

        # 計算逾期天數 (第 5 欄為 deadline)
        statusMsg = self.calculateDeadlineStatus(rowData[5])
        table.setItem(currentRowCount, 6, QTableWidgetItem(statusMsg))

    def calculateDeadlineStatus(self, deadlineStr):
        """計算是否逾期"""
        if not deadlineStr: return "無期限"
        try:
            deadline = datetime.strptime(deadlineStr, "%Y-%m-%d").date()
            today = datetime.now().date()
            delta = (deadline - today).days
            if delta < 0:
                return f"逾期 {-delta} 日"
            elif delta == 0:
                return "今日到期"
            else:
                return f"剩餘 {delta} 天"
        except:
            return "日期格式錯誤"

    def executeDispatch(self):
        """執行發文動作 (批次處理所有表格內的文號)"""
        table = self.ui.tableWidget
        rowCount = table.rowCount()
        
        if rowCount == 0:
            QMessageBox.warning(self, "提醒", "清單內無資料可供發文")
            return
        
        # 取得清單內所有文號
        docList = [table.item(i, 0).text() for i in range(rowCount)]
        
        reply = QMessageBox.question(self, '確認發文', f'是否確定針對這 {rowCount} 件公文執行發文？',
                                     QMessageBox.Yes | QMessageBox.No, QMessageBox.No)
        
        if reply == QMessageBox.Yes:
            try:
                connection = sqlite3.connect(self.dbPath)
                cursor = connection.cursor()
                
                # 批次更新狀態
                for sn in docList:
                    sqlUpdate = "UPDATE task_assignment SET subject = subject || ' (已發文)' WHERE serial_no = ?"
                    cursor.execute(sqlUpdate, (sn,))
                
                connection.commit()
                connection.close()
                
                QMessageBox.information(self, "成功", f"共 {rowCount} 件公文已完成發文。")
                table.setRowCount(0)
                
            except Exception as e:
                QMessageBox.critical(self, "失敗", f"發文過程發生錯誤: {str(e)}")

class MainMenu(QDialog):
    """主選單邏輯"""
    def __init__(self):
        super().__init__()
        self.uiPath = getResourcePath("公文輸入系統.ui")
        self.loadUi()
        self.bindButtons()

    def loadUi(self):
        loader = QUiLoader()
        file = QFile(self.uiPath)
        if file.open(QFile.ReadOnly):
            self.ui = loader.load(file, self)
            file.close()

    def bindButtons(self):
        self.ui.btn_report_assignment.clicked.connect(lambda: self.switchWindow(0))
        self.ui.btn_receive_assignment.clicked.connect(lambda: self.switchWindow(1))
        self.ui.btn_report_case.clicked.connect(lambda: self.switchWindow(2))
        self.ui.btn_generate_receipt.clicked.connect(lambda: self.switchWindow(3))
        self.ui.btn_exit.clicked.connect(self.ui.close)

    def switchWindow(self, index):
        self.workWin = MainWindow(tabIndex=index)
        self.workWin.ui.show()
        self.ui.close()

if __name__ == "__main__":
    app = QApplication(sys.argv)
    menu = MainMenu()
    menu.ui.show()
    sys.exit(app.exec())