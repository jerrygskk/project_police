        border-bottom: 1px solid #b2bec3;
        padding-top: 4px;
        padding-left: 4px;
    }
    QLabel#versionLabel {
        font-size: 10pt;
        color: rgba(45, 52, 54, 150);
        font-weight: bold;
    }
